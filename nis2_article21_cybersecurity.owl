    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleMultiFactorAuthentication">
        <rdf:type rdf:resource="https://w3id.org/nis2/article21#MultiFactorAuthentication"/>
        <rdfs:label>Example Multi-Factor Authentication</rdfs:label>
        <measureDescription xmlns="https://w3id.org/nis2/article21#">Deployment of MFA or continuous authentication for privileged and remote access to network and information systems</measureDescription>
        <isAppropriate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isAppropriate>
        <isProportionate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isProportionate>
        <isStateOfTheArt xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isStateOfTheArt>
        <basedOnStandard xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#CISControls"/>
        <addressesRisk xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#DataBreachRisk"/>
        <preventsIncident xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#UnauthorizedAccessIncident"/>
        <appliesToSystem xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#InternalITInfrastructure"/>
        <appliesToSystem xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#CoreBankingSystem"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleSecureCommunications">
        <rdf:type rdf:resource="https://w3id.org/nis2/article21#SecureCommunications"/>
        <rdfs:label>Example Secure Communications</rdfs:label>
        <measureDescription xmlns="https://w3id.org/nis2/article21#">Secured voice, video and text communications channels including end-to-end encrypted messaging and secured emergency communication systems</measureDescription>
        <isAppropriate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isAppropriate>
        <isProportionate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isProportionate>
        <isStateOfTheArt xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isStateOfTheArt>
        <basedOnStandard xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ENISAGuidelines"/>
        <addressesRisk xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#DataBreachRisk"/>
    </owl:NamedIndividual>

    <!--
        ExampleCompliantEntity — demonstrates positive classification by implementing
        all 12 operational classes.
    -->
    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleCompliantEntity">
        <rdf:type rdf:resource="https://w3id.org/nis2/article21#EssentialEntity"/>
        <rdfs:label>Example Compliant Essential Entity</rdfs:label>
        <rdfs:comment>An essential entity that implements all 12 operational classes covering the
        ten Article 21(2)(a)-(j) categories, with point (j) refined into three modeled subcomponents.
        An OWL 2 reasoner can infer this individual as a CompliantEntity.</rdfs:comment>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleRiskAnalysisPolicy"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleIncidentHandling"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleBusinessContinuity"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleSupplyChainSecurity"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleSecureDevelopment"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleEffectivenessAssessment"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleBasicCyberHygiene"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleTrainingAwareness"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleHumanResourcesSecurity"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleEncryption"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleMultiFactorAuthentication"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleSecureCommunications"/>
    </owl:NamedIndividual>

    <!--
        ExampleNonCompliantEntity — linked to 5 of the 12 operational classes.
    -->
    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleNonCompliantEntity">
        <rdf:type rdf:resource="https://w3id.org/nis2/article21#ImportantEntity"/>
        <rdfs:label>Example Non-Compliant Important Entity</rdfs:label>
        <rdfs:comment>An important entity linked to 5 of the 12 operational classes. It does not
        satisfy the positive CompliantEntity definition in the asserted example graph.</rdfs:comment>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleRiskAnalysisPolicy"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleIncidentHandling"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleEncryption"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleBasicCyberHygiene"/>
        <implementsMeasure xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#ExampleTrainingAwareness"/>
    </owl:NamedIndividual>

