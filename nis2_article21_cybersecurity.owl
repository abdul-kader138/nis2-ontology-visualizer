    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleTrainingAwareness">
        <rdf:type rdf:resource="https://w3id.org/nis2/article21#TrainingAwareness"/>
        <rdfs:label>Example Training and Awareness</rdfs:label>
        <measureDescription xmlns="https://w3id.org/nis2/article21#">Cybersecurity awareness training programmes for all personnel, and specialised training for security staff</measureDescription>
        <isAppropriate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isAppropriate>
        <isProportionate xmlns="https://w3id.org/nis2/article21#" rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isProportionate>
