        <addressesRisk xmlns="https://w3id.org/nis2/article21#" rdf:resource="https://w3id.org/nis2/article21#InsiderThreatRisk"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="https://w3id.org/nis2/article21#ExampleHumanResourcesSecurity">
